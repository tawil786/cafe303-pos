generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  customerName String
  drinkName    String
  drinkType    String // "special" or "custom"
  base         String?
  milk         String
  sweetener    String
  temperature  String
  notes        String?
  status       String   @default("pending") // "pending" or "complete"
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
